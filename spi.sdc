set_output_delay -clock [get_clocks clk] -add_delay -max 1.0 [get_ports {slave_rx[2]}]
set_output_delay -clock [get_clocks clk] -add_delay -max 1.0 [get_ports {slave_rx[1]}]
set_output_delay -clock [get_clocks clk] -add_delay -max 1.0 [get_ports {slave_rx[0]}]
set_output_delay -clock [get_clocks clk] -add_delay -max 1.0 [get_ports slave_data_valid]
set_max_fanout 20.000 [current_design]
set_input_transition 0.12 [get_ports clk]
set_input_transition 0.12 [get_ports rst_n]
set_input_transition 0.12 [get_ports start]
set_input_transition 0.12 [get_ports {master_tx[7]}]
set_input_transition 0.12 [get_ports {master_tx[6]}]
set_input_transition 0.12 [get_ports {master_tx[5]}]
set_input_transition 0.12 [get_ports {master_tx[4]}]
set_input_transition 0.12 [get_ports {master_tx[3]}]
set_input_transition 0.12 [get_ports {master_tx[2]}]
set_input_transition 0.12 [get_ports {master_tx[1]}]
set_input_transition 0.12 [get_ports {master_tx[0]}]
set_input_transition 0.12 [get_ports {slave_tx[7]}]
set_input_transition 0.12 [get_ports {slave_tx[6]}]
set_input_transition 0.12 [get_ports {slave_tx[5]}]
set_input_transition 0.12 [get_ports {slave_tx[4]}]
